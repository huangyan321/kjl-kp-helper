{
  "publisher": "huishi",
  "name": "kjl-kp-helper",
  "displayName": "Task Branch Manager",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "description": "Kaptain 开发任务与 Git 分支管理插件",
  "author": "",
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "main": "./dist/index.cjs",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "dist/*",
    "res/*"
  ],
  "engines": {
    "vscode": "^1.97.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kpHelper",
          "title": "KJL Kaptain Helper",
          "icon": "res/icon.svg"
        }
      ]
    },
    "views": {
      "kpHelper": [
        {
          "id": "kpHelperPanel",
          "name": "任务分支"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kpHelperPanel",
        "contents": "请登录 Kaptain 平台以查看您的开发任务。\n[登录](command:kpHelper.login)",
        "when": "!kpHelperLogin"
      }
    ],
    "commands": [
      {
        "command": "kpHelper.login",
        "title": "登录",
        "category": "Kaptain Helper"
      },
      {
        "command": "kpHelper.logout",
        "title": "退出登录",
        "category": "Kaptain Helper"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Kaptain Helper",
      "properties": {
        "kpHelper.kaBaseUrl": {
          "type": "string",
          "default": "https://kaptain.qunhequnhe.com",
          "description": "KA 平台接口地址"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --external vscode",
    "dev": "nr build --watch --sourcemap",
    "prepare": "nr update",
    "update": "vscode-ext-gen --output src/generated/meta.ts",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "nr build",
    "release": "bumpp",
    "ext:package": "vsce package --no-dependencies",
    "ext:publish": "vsxpub --no-dependencies"
  },
  "dependencies": {
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "^3.7.1",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "ovsx": "^0.10.7",
    "reactive-vscode": "^1.0.0-beta.2",
    "taze": "^19.9.2",
    "tsdown": "^0.19.0-beta.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "vscode-ext-gen": "^1.5.1",
    "vsxpub": "^0.1.2"
  }
}
